 "html": "<div style=\"text-align:center;\">\n    <h1>Wanderlust Travels</h1>\n    {% set logo = frappe.db.get_single_value(\"Agency Settings\", \"logo\") %}\n\n    {% if logo %}\n        <img src=\"{{ logo }}\" style=\"max-height:100px;\"><br>\n    {% endif %}\n\n    <p>Booking Voucher</p>\n</div>\n\n<hr>\n\n<p><b>Booking ID:</b> {{ doc.booking_number }}</p>\n<p><b>Customer:</b> {{ doc.customer }}</p>\n<p><b>Booking Date:</b> {{ doc.booking_date}}</p>\n\n<hr>\n\n<h3>Packages</h3>\n\n<table border=\"1\" width=\"100%\" cellspacing=\"0\" cellpadding=\"5\">\n    <tr>\n        <th>Package</th>\n        <th>Quantity</th>\n        <th>Price</th>\n        <th>Total</th>\n    </tr>\n\n    {% for item in doc.booked_package %}\n    <tr>\n        <td>{{ item.travel_package }}</td>\n        <td>{{ item.quantity }}</td>\n        <td>{{ item.price }}</td>\n        <td>{{ item.total }}</td>\n    </tr>\n    {% endfor %}\n</table>\n\n<hr>\n\n<p><b>Total Amount:</b> {{ doc.total_amount }}</p>\n<p><b>GST:</b> {{ doc.gst_amount }}</p>\n<p><b>Grand Total:</b> {{ doc.grand_total }}</p>\n\n<hr>\n<div style=\"text-align:center;\">\n    <p>Scan for Booking Details</p>\n    <img src=\"https://api.qrserver.com/v1/create-qr-code/?size=50x50&data={'Booking Id':'{{ doc.booking_number }}','Customer Name':'{{ doc.customer_name}}','Total Amount':'{{ doc.grand_total}}'}\">\n</div>\n\n<p style=\"text-align:center;\">Thank you for booking with us!<br> Happy Journey!!</p>",
